{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aether.dev/schemas/release/evidence-bundle-v1.json",
  "title": "AETHER immutable release evidence bundle manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "official",
    "candidate",
    "policy",
    "workflow",
    "evidence",
    "waivers",
    "package",
    "package_attestation_subject_sha256",
    "file_integrity_manifest",
    "sboms",
    "subjects",
    "computed_verdict",
    "blockers",
    "verifier"
  ],
  "properties": {
    "schema_version": { "const": "aether.release-evidence-bundle.v1" },
    "bundle_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "official": { "type": "boolean" },
    "candidate": { "$ref": "https://aether.dev/schemas/release/evidence-envelope-v1.json#/$defs/candidate" },
    "policy": { "$ref": "#/$defs/file" },
    "workflow": { "$ref": "https://aether.dev/schemas/release/evidence-envelope-v1.json#/$defs/workflow" },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate_id", "evidence_id", "path", "sha256", "byte_size", "observed_status"],
        "properties": {
          "gate_id": { "type": "string" },
          "evidence_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "byte_size": { "type": "integer", "minimum": 0 },
          "observed_status": { "enum": ["passed", "failed", "error", "skipped"] }
        }
      }
    },
    "waivers": { "type": "array", "items": { "$ref": "#/$defs/file" } },
    "package": { "$ref": "#/$defs/file" },
    "package_attestation_subject_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "file_integrity_manifest": { "$ref": "#/$defs/file" },
    "sboms": { "type": "array", "items": { "$ref": "#/$defs/file" } },
    "subjects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["present", "missing"] },
          "file": { "$ref": "#/$defs/file" }
        }
      }
    },
    "computed_verdict": { "enum": ["passed", "blocked"] },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "algorithm"],
      "properties": {
        "version": { "const": "aether-release-evidence-verifier-v1" },
        "algorithm": { "const": "sha256-canonical-json-v1" }
      }
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "byte_size", "media_type"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "byte_size": { "type": "integer", "minimum": 0 },
        "media_type": { "type": "string", "minLength": 1 }
      }
    }
  }
}
