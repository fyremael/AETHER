{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aether.dev/schemas/release/evidence-envelope-v1.json",
  "title": "AETHER release evidence envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "gate_id",
    "official",
    "candidate",
    "workflow",
    "command",
    "started_at",
    "ended_at",
    "exit_code",
    "attempt_history",
    "inputs",
    "observed_status",
    "metrics",
    "output",
    "valid_until"
  ],
  "properties": {
    "schema_version": { "const": "aether.release-evidence-envelope.v1" },
    "evidence_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "gate_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$" },
    "official": { "type": "boolean" },
    "candidate": { "$ref": "#/$defs/candidate" },
    "workflow": { "$ref": "#/$defs/workflow" },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "working_directory": { "type": "string" },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": "string", "format": "date-time" },
    "exit_code": { "type": "integer" },
    "attempt_history": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/attempt" }
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/digestDescriptor" }
    },
    "observed_status": {
      "enum": ["passed", "failed", "error", "skipped"]
    },
    "metrics": { "type": "object" },
    "output": { "$ref": "#/$defs/outputDescriptor" },
    "valid_until": { "type": ["string", "null"], "format": "date-time" }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit_sha", "tree_sha", "ref", "dirty"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "commit_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "tree_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "ref": { "type": "string", "minLength": 1 },
        "dirty": { "const": false }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_file",
        "run_id",
        "attempt",
        "job_id",
        "runner",
        "host",
        "tool_versions"
      ],
      "properties": {
        "workflow_file": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "minLength": 1 },
        "attempt": { "type": "integer", "minimum": 1 },
        "job_id": { "type": "string", "minLength": 1 },
        "runner": { "type": "string", "minLength": 1 },
        "host": { "type": "string", "minLength": 1 },
        "tool_versions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt", "started_at", "ended_at", "exit_code", "status", "failure_class"],
      "properties": {
        "attempt": { "type": "integer", "minimum": 1 },
        "started_at": { "type": "string", "format": "date-time" },
        "ended_at": { "type": "string", "format": "date-time" },
        "exit_code": { "type": "integer" },
        "status": { "enum": ["passed", "failed", "error", "skipped"] },
        "failure_class": { "enum": ["none", "semantic", "infrastructure"] }
      }
    },
    "digestDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path", "sha256", "byte_size"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "byte_size": { "type": "integer", "minimum": 0 }
      }
    },
    "outputDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path", "sha256", "byte_size", "media_type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "byte_size": { "type": "integer", "minimum": 0 },
        "media_type": { "type": "string", "minLength": 1 }
      }
    }
  }
}
