{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aether.dev/schemas/release/release-subject-v1.json",
  "title": "AETHER candidate-bound release subject",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject_identity",
    "subject_id",
    "candidate",
    "producer",
    "observed_status",
    "package",
    "source_runs",
    "source_artifacts",
    "generated_at",
    "valid_until",
    "metrics",
    "observation"
  ],
  "properties": {
    "schema_version": { "const": "aether.release-subject.v1" },
    "subject_identity": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "subject_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$" },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit_sha", "tree_sha", "ref", "dirty"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "commit_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "tree_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "ref": { "type": "string", "minLength": 1 },
        "dirty": { "const": false }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_file", "workflow_name", "job_name", "run_id", "attempt", "runner", "host"],
      "properties": {
        "workflow_file": { "type": "string", "minLength": 1 },
        "workflow_name": { "type": "string", "minLength": 1 },
        "job_name": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "pattern": "^[0-9]+$" },
        "attempt": { "type": "integer", "minimum": 1 },
        "runner": { "type": "string", "minLength": 1 },
        "host": { "type": "string", "minLength": 1 }
      }
    },
    "observed_status": { "enum": ["passed", "failed", "error", "skipped"] },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "source_artifacts": { "type": "array", "items": { "type": "object" } },
    "source_runs": { "type": "array", "items": { "type": "object" } },
    "generated_at": { "type": "string", "format": "date-time" },
    "valid_until": { "type": "string", "format": "date-time" },
    "metrics": { "type": "object" },
    "observation": { "type": "object" }
  }
}
